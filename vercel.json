{
  "version": 2,
  "buildCommand": "cd server && npm install --legacy-peer-deps && npm run build",
  "outputDirectory": "server/dist",
  "installCommand": "cd server && npm install --legacy-peer-deps",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/server/api/index.js"
    }
  ]
}
